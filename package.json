{
	"name": "@meteora-ag/cp-amm-sdk",
	"version": "1.4.0",
	"packageManager": "pnpm@10.15.0",
	"description": "SDK for DAMM v2",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"source": "./src/index.ts",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./kit": {
			"types": "./dist/kit/index.d.ts",
			"import": "./dist/kit/index.mjs",
			"require": "./dist/kit/index.js"
		}
	},
	"author": "Minh Do <minh@raccoons.dev>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MeteoraAg/damm-v2-sdk.git"
	},
	"files": [
		"dist/**"
	],
	"scripts": {
		"lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
		"lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
		"build": "tsup",
		"clean": "rm -rf dist && rm -rf node_modules",
		"start": "npm run build -- --watch",
		"check:kit-imports": "tsx scripts/check-kit-imports.ts",
		"test": "vitest run",
		"test:kit-compat": "vitest run tests/kit-compat",
		"test:all": "pnpm check:kit-imports && pnpm build && pnpm check-types && pnpm test && pnpm test:kit-compat",
		"generate:kit": "tsx scripts/generate-kit-client.ts",
		"check-types": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/invariant": "^2.2.35",
		"prettier": "^3.7.4",
		"solana-bankrun": "^0.4.0",
		"ts-node": "^10.9.2",
		"tsup": "^8.4.0",
		"tsx": "^4.20.3",
		"typescript": "^5.8.2",
		"vitest": "^4.0.16"
	},
	"dependencies": {
		"@coral-xyz/anchor": "^0.31.0",
		"@solana-program/compute-budget": "^0.15.0",
		"@solana-program/system": "^0.12.0",
		"@solana-program/token": "^0.12.0",
		"@solana/compat": "^6.5.0",
		"@solana/kit": "^6.5.0",
		"@solana/spl-token": "^0.4.8",
		"@solana/web3.js": "^1.95.3",
		"@types/bn.js": "^5.1.0",
		"bn.js": "^5.2.2",
		"chain": "^0.4.0",
		"decimal.js": "^10.4.2",
		"invariant": "^2.2.4"
	}
}
