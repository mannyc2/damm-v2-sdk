{
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": false,
    "target": "es6",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "es2015"
    ],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "scripts"
  ]
}
